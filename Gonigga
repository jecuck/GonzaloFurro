import os
from datetime import datetime


class Evento:
    def __init__(self, fechita, horita, textito):
        self.fecha = fechita
        self.hora = horita
        self.texto = textito

    def __str__(self):
        return f"{self.fecha} | {self.hora} | {self.texto}"


class Agenda:
    def __init__(self):
        self.eventos = []
        self.archivo = "Eventos.txt"

    def cargar(self):
        if os.path.exists(self.archivo) and not self.eventos:
            with open(self.archivo, "rt", encoding="utf-8") as f:
                for linea in f:
                    datos = linea.strip().split(" | ")
                    if len(datos) == 3:
                        self.eventos.append(Evento(datos[0], datos[1], datos[2]))
            print(f"--- {len(self.eventos)} eventos cargados ---")

    def guardar(self):
        with open(self.archivo, "wt", encoding="utf-8") as f:
            for e in self.eventos:
                f.write(f"{e.fecha} | {e.hora} | {e.texto}\n")

    def agregar(self):
        print("\nNuevo Evento")
        f = input("Fecha (DD/MM/YYYY): ")
        h = input("Hora (HH:MM): ")
        t = input("Descripción: ")
        self.eventos.append(Evento(f, h, t))

